lua/lzio.c.o:
	cd /home/runner/work/ptusa_main/ptusa_main/build-debug && $(MAKE) $(MAKESILENT) -f deps/lua/CMakeFiles/liblua.dir/build.make deps/lua/CMakeFiles/liblua.dir/lua/lzio.c.o
	cd /home/runner/work/ptusa_main/ptusa_main/build-debug && $(MAKE) $(MAKESILENT) -f deps/lua/CMakeFiles/liblua_static.dir/build.make deps/lua/CMakeFiles/liblua_static.dir/lua/lzio.c.o
.PHONY : lua/lzio.c.o

lua/lzio.i: lua/lzio.c.i
.PHONY : lua/lzio.i

# target to preprocess a source file
lua/lzio.c.i:
	cd /home/runner/work/ptusa_main/ptusa_main/build-debug && $(MAKE) $(MAKESILENT) -f deps/lua/CMakeFiles/liblua.dir/build.make deps/lua/CMakeFiles/liblua.dir/lua/lzio.c.i
	cd /home/runner/work/ptusa_main/ptusa_main/build-debug && $(MAKE) $(MAKESILENT) -f deps/lua/CMakeFiles/liblua_static.dir/build.make deps/lua/CMakeFiles/liblua_static.dir/lua/lzio.c.i
